        <mxCell id="r4iEPXtKsYzcGjQRxESC-240" parent="1" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;align=center;fontSize=14;" value="Reglas de integridad PostgreSQL" vertex="1">
          <mxGeometry height="700" width="290" x="510" y="-425" as="geometry" />
        </mxCell>
        <mxCell id="r4iEPXtKsYzcGjQRxESC-241" parent="r4iEPXtKsYzcGjQRxESC-240" style="text;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=12;whiteSpace=wrap;html=1;" value="&lt;div&gt;Reglas de integridad PostgreSQL&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. especialidad.nombre debe ser UNIQUE.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. medico.numero_colegiado debe ser UNIQUE.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3. paciente.correo debe ser UNIQUE cuando no sea NULL.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;4. usuario_sistema.usuario debe ser UNIQUE.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;5. usuario_sistema.correo debe ser UNIQUE.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;6. horario_medico debe evitar horarios duplicados para el mismo médico, día, hora_inicio y hora_fin.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;7. cita.estado solo puede ser:&lt;/div&gt;&lt;div&gt;programada, confirmada, atendida, cancelada, no_asistio.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;8. cita.hora_fin debe ser mayor que cita.hora_inicio.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;9. cita debe evitar doble reserva para el mismo médico, fecha y hora.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;10. factura.estado solo puede ser:&lt;/div&gt;&lt;div&gt;pendiente, pagada_parcial, pagada, anulada.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;11. factura.total debe ser mayor o igual a 0.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;12. detalle_factura.cantidad debe ser mayor que 0.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;13. detalle_factura.precio_unitario debe ser mayor o igual a 0.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;14. detalle_factura.subtotal debe ser mayor o igual a 0.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;15. pago.monto debe ser mayor que 0.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;16. pago.estado solo puede ser:&lt;/div&gt;&lt;div&gt;registrado, anulado.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;17. Una factura anulada no puede recibir pagos.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;18. Los pagos de una factura no pueden superar el total de la factura.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;19. Una cita cancelada debe tener motivo_cancelacion.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;20. El historial clínico solo se registra en MongoDB para citas en estado atendida.&lt;/div&gt;" vertex="1">
          <mxGeometry height="674" width="290" y="26" as="geometry" />
        </mxCell>
